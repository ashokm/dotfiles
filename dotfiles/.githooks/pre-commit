#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

branch_name="$(git symbolic-ref --quiet --short HEAD || true)"

# Detached HEAD is valid for workflows such as bisect and rebase.
if [[ -z "$branch_name" ]]; then
  exit 0
fi

# Mainline branches are exempt from the branch naming convention.
if [[ "$branch_name" == "main" ]] ||
  [[ "$branch_name" == "master" ]]; then
  exit 0
fi

# Keep the allowed types in sync with the commit message convention.
branch_pattern='^(feat|fix|docs|style|refactor|perf|test|chore)/[a-z0-9]+(-[a-z0-9]+)*$'

if [[ "$branch_name" =~ $branch_pattern ]]; then
  exit 0
fi

cat >&2 << EOF
ERROR: invalid branch name '$branch_name'.
Expected: <type>/<short-description>

Allowed types:
feat, fix, docs, style, refactor, perf, test, chore

Description must be lowercase kebab-case.
EOF
exit 1
